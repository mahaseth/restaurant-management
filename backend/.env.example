APP_URL = "http://localhost:3000"
# IMPORTANT (phone QR testing):
# `localhost` on your phone is NOT your PC. Set APP_URL to:
#   http://<your-LAN-IP>:<frontend-port>
# Example (from `next dev` output):
#   http://192.168.0.154:3001
NAME="Restaurant management API"
PORT=5000
VERSION=1.0.0
JWT_SECRET="your_jwt_secret_key_here"
FEATURE_USER_ENABLED=1
FEATURE_ADMIN_ENABLED=0
# Example MongoDB URLs:
# No auth/local: mongodb://localhost:27017/restaurantdb
# With user (authSource=admin): mongodb://appuser:password@localhost:27017/restaurantdb?authSource=admin
MONGODB_URL="mongodb://localhost:27017/restaurantdb"

CLOUDINARY_CLOUD_NAME="cloud-name"
CLOUDINARY_API_KEY="api-key"
CLOUDINARY_API_SECRET="secret-key"

EMAIL_API_KEY="your_email_api_key_here"

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret from Stripe CLI (`stripe listen`) or dashboard
STRIPE_WEBHOOK_SECRET="whsec_..."
# Full URL of your frontend (used for Connect onboarding return/refresh URLs)
CLIENT_URL="http://localhost:3000"

# AI Studio — pick ONE: Azure OpenAI OR OpenAI (direct)

# --- Azure OpenAI (recommended if you use Azure) ---
AZURE_OPENAI_API_KEY="your-azure-key"
# Resource name only (no https): builds https://{name}.openai.azure.com/
AZURE_RESOURCE_NAME="your-resource-name"
# Optional: full endpoint override instead of resource name
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# API version (required by Azure; default in app is 2024-10-21)
# AZURE_OPENAI_API_VERSION="2024-10-21"
# Deployment names exactly as in Azure AI Studio (must match your deployments)
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"
# AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o"
# If embedding length differs from 1536, set after you deploy the model
# AZURE_EMBEDDING_DIMENSIONS="1536"

# --- OpenAI API (direct) — used only if Azure vars above are not set ---
OPENAI_API_KEY="sk-..."
OPENAI_CHAT_MODEL="gpt-4o"

# Supabase Postgres connection URI (Settings → Database → Connection string → URI)
# Used for pgvector menu_catalog_rows (not the anon Supabase REST key).
SUPABASE_DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"